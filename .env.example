# Copy to .env and fill in your own values.
# NEVER commit .env. NEVER share private keys in chat.
# Generate a fresh key for each environment (dev/staging/prod).

# === Wallets ===
ZG_TESTNET_PRIVATE_KEY=0x<your-0g-testnet-key>
AGENT_OWNER_PRIVATE_KEY=0x<your-key>
AETHER_TEE_AUTHORITY_KEY=0x<your-key>
SEPOLIA_PRIVATE_KEY=0x<your-key>

# === 0G Galileo Testnet ===
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16601
ZG_INDEXER_RPC_URL=https://indexer-storage-testnet-turbo.0g.ai
ZG_EXPLORER=https://chainscan-galileo.0g.ai
ZG_STORAGE_EXPLORER=https://storagescan-galileo.0g.ai

# === Sepolia (ERC-8004) ===
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
SEPOLIA_CHAIN_ID=11155111
ERC8004_IDENTITY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION=0x8004B663056A597Dffe9eCcC1965A193B7388713

# === Aether (filled after deploy) ===
AETHER_VERIFIER_ADDRESS=
AGENT_NFT_ADDRESS=
AGENT_NFT_BEACON=

# === 0G Compute ===
ZG_COMPUTE_PROVIDER_ADDRESS=
ZG_COMPUTE_DEFAULT_MODEL=glm-5-fp8

# === ENS / Durin ===
ENS_PARENT_NAME=
DURIN_FACTORY=0xDddddDdDDD8Aa1f237b4fa0669cb46892346d22d
DURIN_L1_RESOLVER=0x8A968aB9eb8C084FBC44c531058Fc9ef945c3D61
DURIN_L2_CHAIN=base-sepolia
DURIN_L2_REGISTRY=

# === x402 ===
X402_FACILITATOR=https://api.cdp.coinbase.com/platform/v2/x402
X402_NETWORK=base-sepolia
X402_USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# === KeeperHub ===
KEEPERHUB_API_BASE=https://api.keeperhub.com
KEEPERHUB_MCP_URL=https://mcp.keeperhub.com
KEEPERHUB_TOKEN=
KEEPERHUB_PROJECT_ID=

# === IPFS pinning ===
WEB3_STORAGE_TOKEN=
PINATA_JWT=

# === Flags ===
LOG_LEVEL=info
NODE_ENV=development
